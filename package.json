{
    "name": "@sidekick-coder/zenith-kit",
    "version": "0.1.0",
    "license": "MIT",
    "description": "Package to use with zenith framework",
    "author": "Henrique Oliveira <henriqueoliwork@gmail.com>",
    "homepage": "https://github.com/sidekick-coder/zenith-kit",
    "bin": {
        "zkit": "./bin/zkit.js",
        "zenith": "./bin/zenith.js"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/sidekick-coder/zenith-kit.git"
    },
    "publishConfig": {
        "access": "public"
    },
    "imports": {
        "#client/*": "./src/client/*",
        "#server/*": "./src/server/*",
        "#shared/*": "./src/shared/*"
    },
    "exports": {
        "./shared": {
            "types": "./dist/shared/index.d.mts",
            "import": "./dist/shared/index.mjs",
            "require": "./dist/shared/index.js"
        },
        "./server": {
            "types": "./dist/server/index.d.mts",
            "import": "./dist/server/index.mjs",
            "require": "./dist/server/index.js"
        },
        "./client": {
            "types": "./dist/client/index.d.mts",
            "import": "./dist/client/index.mjs",
            "require": "./dist/client/index.mjs"
        },
        "./components": {
            "types": "./dist/components/index.d.mts",
            "import": "./dist/components/index.es.js",
            "require": "./dist/components/index.es.js"
        },
        "./vite": {
            "import": "./vite/plugins/vite.js",
            "require": "./vite/plugins/vite.js"
        },
        "./styles": "./dist/components/styles.css",
        "./client-globals": {
            "types": "./src/client/zenith-env.d.ts"
        }
    },
    "scripts": {
        "build:tsdown": "tsdown",
        "build:vite": "vite build",
        "build": "npm-run-all -p build:*",
        "test:unit": "vitest --project unit",
        "test:int": "vitest -p integration",
        "test": "npm-run-all -p test:*",
        "release": "node artisan.js release"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "@eslint/json": "^0.14.0",
        "@faker-js/faker": "^10.4.0",
        "@microsoft/api-extractor": "^7.58.7",
        "@types/bcrypt": "^6.0.0",
        "@types/cookie-parser": "^1.4.10",
        "@types/cors": "^2.8.19",
        "@types/supertest": "^7.2.0",
        "better-sqlite3": "^12.10.0",
        "npm-run-all": "^4.1.5"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.1039.0",
        "@aws-sdk/lib-storage": "^3.1039.0",
        "@aws-sdk/s3-request-presigner": "^3.1039.0",
        "@casl/ability": "^6.8.1",
        "@inquirer/prompts": "^8.4.3",
        "@rollup/pluginutils": "^5.3.0",
        "@tailwindcss/vite": "^4.2.4",
        "@types/express": "^5.0.6",
        "@types/js-yaml": "^4.0.9",
        "@types/lodash-es": "^4.17.12",
        "@types/mime": "^3.0.4",
        "@types/ms": "^2.1.0",
        "@types/node": "^25.6.0",
        "@types/node-schedule": "^2.1.8",
        "@types/qs": "^6.15.0",
        "@unhead/vue": "^3.1.0",
        "@vee-validate/valibot": "^4.15.1",
        "@vitejs/plugin-vue": "^6.0.6",
        "@vue/language-core": "^3.1.8",
        "@vue/tsconfig": "^0.9.1",
        "@vueuse/router": "^14.3.0",
        "bcrypt": "^6.0.0",
        "class-variance-authority": "^0.7.1",
        "cli-table3": "^0.6.5",
        "clsx": "^2.1.1",
        "commander": "^14.0.3",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.6",
        "cosmiconfig": "^9.0.1",
        "date-fns": "^4.1.0",
        "dotenv": "^17.4.2",
        "embla-carousel-vue": "^8.6.0",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-vue": "^10.8.0",
        "express": "^5.2.1",
        "fast-glob": "^3.3.3",
        "globals": "^17.5.0",
        "js-yaml": "^4.1.1",
        "kysely": "^0.28.16",
        "lodash-es": "^4.18.1",
        "lucide-vue-next": "^1.0.0",
        "mime": "^4.1.0",
        "ms": "^2.1.3",
        "mysql2": "^3.22.3",
        "node-schedule": "^2.1.1",
        "pg": "^8.20.0",
        "qs": "^6.15.1",
        "reka-ui": "^2.9.6",
        "supertest": "^7.2.2",
        "tailwind-merge": "^3.5.0",
        "tsdown": "^0.21.9",
        "tw-animate-css": "^1.4.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.58.2",
        "ulid": "^3.0.2",
        "undici": "^8.2.0",
        "valibot": "^1.3.1",
        "vaul-vue": "^0.4.1",
        "vee-validate": "^4.15.1",
        "vite-plugin-dts": "^5.0.0",
        "vitest": "^3.2.4",
        "vue-router": "^5.0.6",
        "vue-sonner": "^2.0.9"
    }
}
