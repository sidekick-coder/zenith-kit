{
    "name": "@sidekick-coder/zenith-kit",
    "version": "0.0.12",
    "license": "MIT",
    "description": "Package to use with zenith framework",
    "author": "Henrique Oliveira <henriqueoliwork@gmail.com>",
    "homepage": "https://github.com/sidekick-coder/zenith-kit",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/sidekick-coder/zenith-kit.git"
    },
    "publishConfig": {
        "access": "public"
    },
    "imports": {
        "#client/*": "./src/client/*",
        "#server/*": "./src/server/*",
        "#shared/*": "./src/shared/*"
    },
    "exports": {
        "./shared": {
            "types": "./dist/shared/index.d.mts",
            "import": "./dist/shared/index.mjs",
            "require": "./dist/shared/index.js"
        },
        "./server": {
            "types": "./dist/server/index.d.mts",
            "import": "./dist/server/index.mjs",
            "require": "./dist/server/index.js"
        },
        "./client": {
            "types": "./dist/client/index.d.mts",
            "import": "./dist/client/index.es.js",
            "require": "./dist/client/index.es.js"
        },
        "./vite": {
            "import": "./extras/vite.js",
            "require": "./extras/vite.js"
        },
        "./styles": "./dist/client/styles.css"
    },
    "scripts": {
        "build": "npm run build:server && npm run build:client",
        "build:server": "tsdown",
        "build:client": "vite build",
        "watch": "tsdown --watch",
        "release": "node artisan.js release"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "@eslint/json": "^0.14.0",
        "@types/express": "^5.0.6",
        "@types/js-yaml": "^4.0.9",
        "@types/lodash-es": "^4.17.12",
        "@types/mime": "^3.0.4",
        "@types/ms": "^2.1.0",
        "@types/node": "^25.6.0",
        "@types/qs": "^6.15.0",
        "@vue/language-core": "^3.1.8",
        "@vue/tsconfig": "^0.9.1",
        "commander": "^14.0.3",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-vue": "^10.8.0",
        "globals": "^17.5.0",
        "jiti": "^2.6.1",
        "tsdown": "^0.21.9",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.58.2",
        "vite-plugin-dts": "^5.0.0",
        "vitest": "^3.2.4"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.1039.0",
        "@aws-sdk/lib-storage": "^3.1039.0",
        "@aws-sdk/s3-request-presigner": "^3.1039.0",
        "@casl/ability": "^6.8.1",
        "@rollup/pluginutils": "^5.3.0",
        "@tailwindcss/vite": "^4.2.4",
        "@unhead/vue": "^3.1.0",
        "@vee-validate/valibot": "^4.15.1",
        "@vitejs/plugin-vue": "^6.0.6",
        "better-sqlite3": "^12.9.0",
        "class-variance-authority": "^0.7.1",
        "cli-table3": "^0.6.5",
        "clsx": "^2.1.1",
        "date-fns": "^4.1.0",
        "dotenv": "^17.4.2",
        "embla-carousel-vue": "^8.6.0",
        "fast-glob": "^3.3.3",
        "js-yaml": "^4.1.1",
        "kysely": "^0.28.16",
        "lodash-es": "^4.18.1",
        "lucide-vue-next": "^1.0.0",
        "mime": "^4.1.0",
        "ms": "^2.1.3",
        "mysql2": "^3.22.3",
        "pg": "^8.20.0",
        "qs": "^6.15.1",
        "reka-ui": "^2.9.6",
        "tailwind-merge": "^3.5.0",
        "tw-animate-css": "^1.4.0",
        "valibot": "^1.3.1",
        "vaul-vue": "^0.4.1",
        "vee-validate": "^4.15.1",
        "vue-router": "^5.0.6",
        "vue-sonner": "^2.0.9"
    }
}
